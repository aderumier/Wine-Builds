 }
 
+static BOOL is_wine_virtual_raw_mouse_device_name( const WCHAR *name )
+{
+    static const WCHAR prefix[] = L"\\\\?\\WINE#VirtualRawMouse";
+
+    if (!name) return FALSE;
+    return !wcsncmp( name, prefix, wcslen( prefix ) );
+}
+
+/***********************************************************************
+ *              GetRawInputDeviceInfoW   (USER32.@)
+ */
+UINT WINAPI GetRawInputDeviceInfoW( HANDLE device, UINT command, void *data, UINT *size )
+{
+    WCHAR wide[MAX_PATH];
+    UINT wide_size = ARRAYSIZE(wide);
+    UINT ret;
+    int nbytes;
+
+    TRACE( "device %p, command %#x, data %p, size %p.\n", device, command, data, size );
+
+    if (!size) return ~0U;
+    if (command != RIDI_DEVICENAME)
+        return NtUserGetRawInputDeviceInfo( device, command, data, size );
+
+    ret = NtUserGetRawInputDeviceInfo( device, command, wide, &wide_size );
+    if (ret == ~0U) return ret;
+
+    if (!is_wine_virtual_raw_mouse_device_name( wide ))
+        return NtUserGetRawInputDeviceInfo( device, command, data, size );
+
+    nbytes = WideCharToMultiByte( CP_ACP, 0, wide, -1, NULL, 0, NULL, NULL );
+    if (!data)
+    {
+        *size = nbytes;
+        return 0;
+    }
+    if (*size < nbytes)
+    {
+        SetLastError( ERROR_INSUFFICIENT_BUFFER );
+        *size = nbytes;
+        return ~0U;
+    }
+    WideCharToMultiByte( CP_ACP, 0, wide, -1, data, nbytes, NULL, NULL );
+    *size = nbytes;
+    return nbytes;
+}
+
 /***********************************************************************
  *              GetRawInputDeviceInfoA   (USER32.@)
  */
 UINT WINAPI GetRawInputDeviceInfoA( HANDLE device, UINT command, void *data, UINT *size )

