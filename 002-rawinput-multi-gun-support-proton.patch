+
+/* ─── Socket injection for virtual mice ─── */
+#include <sys/socket.h>
+#include <sys/stat.h>
+#include <sys/un.h>
+#include <unistd.h>
+#include <errno.h>
+#include <pthread.h>
+
+#define WINE_MOUSE_SOCKET_DEFAULT "/tmp/wine-mouse.sock"
+#define WINE_MOUSE_PKT_SIZE 12
+#define WINE_MOUSE_RING_SIZE 1024
+
+#pragma pack(push, 1)
+struct wine_mouse_packet {
+    unsigned char mouse_index;
+    unsigned char buttons;
+    unsigned char reserved0;
+    unsigned char reserved1;
+    int x;
+    int y;
+};
+#pragma pack(pop)
+
+static struct wine_mouse_packet mouse_ring[WINE_MOUSE_RING_SIZE];
+static volatile unsigned int mouse_ring_head;
+static volatile unsigned int mouse_ring_tail;
+static unsigned char socket_prev_buttons[WINE_RAW_MOUSE_MAX];
+static int mouse_socket_active;
+static int mouse_socket_screen_w;
+static int mouse_socket_screen_h;
+
+static void process_mouse_socket_packets( void )
+{
+    unsigned int tail, head;
+
+    if (!mouse_socket_active) return;
+
+    head = __atomic_load_n( &mouse_ring_head, __ATOMIC_ACQUIRE );
+    tail = __atomic_load_n( &mouse_ring_tail, __ATOMIC_RELAXED );
+
+    while (tail != head)
+    {
+        struct wine_mouse_packet *pkt = &mouse_ring[tail % WINE_MOUSE_RING_SIZE];
+        unsigned int handle = 0x10001 + pkt->mouse_index;
+        unsigned char changed;
+        INPUT input;
+
+        if (pkt->mouse_index >= socket_rawmouse_count || pkt->mouse_index >= WINE_RAW_MOUSE_MAX) goto next;
+
+        /* Inject absolute motion */
+        memset( &input, 0, sizeof(input) );
+        input.type = INPUT_MOUSE;
+        input.mi.dwFlags = MOUSEEVENTF_MOVE | MOUSEEVENTF_ABSOLUTE;
+        input.mi.dwExtraInfo = handle;
+        input.mi.dx = pkt->x;
+        input.mi.dy = pkt->y;
+        input.mi.time = NtGetTickCount();
+        NtUserSendHardwareInput( 0, 0, &input, 0 );
+
+        /* Inject button changes */
+        changed = socket_prev_buttons[pkt->mouse_index] ^ pkt->buttons;
+        if (changed)
+        {
+            memset( &input, 0, sizeof(input) );
+            input.type = INPUT_MOUSE;
+            input.mi.dwExtraInfo = handle;
+            input.mi.dx = pkt->x;
+            input.mi.dy = pkt->y;
+            input.mi.dwFlags = MOUSEEVENTF_MOVE | MOUSEEVENTF_ABSOLUTE;
+            input.mi.time = NtGetTickCount();
+            if (changed & 1)
+                input.mi.dwFlags |= (pkt->buttons & 1) ? MOUSEEVENTF_LEFTDOWN : MOUSEEVENTF_LEFTUP;
+            if (changed & 2)
+                input.mi.dwFlags |= (pkt->buttons & 2) ? MOUSEEVENTF_RIGHTDOWN : MOUSEEVENTF_RIGHTUP;
+            if (changed & 4)
+                input.mi.dwFlags |= (pkt->buttons & 4) ? MOUSEEVENTF_MIDDLEDOWN : MOUSEEVENTF_MIDDLEUP;
+            NtUserSendHardwareInput( 0, 0, &input, 0 );
+            socket_prev_buttons[pkt->mouse_index] = pkt->buttons;
+        }
+    next:
+        tail++;
+    }
+    __atomic_store_n( &mouse_ring_tail, tail, __ATOMIC_RELEASE );
+}
+
+static void *wine_mouse_socket_thread( void *arg )
+{
+    const char *sock_path;
+    struct sockaddr_un addr;
+    int srv, client;
+
+    sock_path = getenv( "WINE_MOUSE_SOCKET" );
+    if (!sock_path) sock_path = WINE_MOUSE_SOCKET_DEFAULT;
+
+    unlink( sock_path );
+    srv = socket( AF_UNIX, SOCK_STREAM, 0 );
+    if (srv < 0) { FIXME( "mouse socket: socket() failed errno=%d\n", errno ); return NULL; }
+
+    memset( &addr, 0, sizeof(addr) );
+    addr.sun_family = AF_UNIX;
+    {
+        size_t path_len = strlen( sock_path );
+        if (path_len >= sizeof(addr.sun_path)) path_len = sizeof(addr.sun_path) - 1;
+        memcpy( addr.sun_path, sock_path, path_len );
+    }
+
+    if (bind( srv, (struct sockaddr *)&addr, sizeof(addr) ) < 0)
+    { FIXME( "mouse socket: bind() failed errno=%d\n", errno ); close( srv ); return NULL; }
+
+    chmod( sock_path, 0666 );
+    listen( srv, 4 );
+    FIXME( "Mouse socket listening on %s\n", sock_path );
+
+    while (mouse_socket_active)
+    {
+        fd_set rfds;
+        struct timeval tv;
+        FD_ZERO( &rfds );
+        FD_SET( srv, &rfds );
+        tv.tv_sec = 1; tv.tv_usec = 0;
+        if (select( srv + 1, &rfds, NULL, NULL, &tv ) <= 0) continue;
+
+        client = accept( srv, NULL, NULL );
+        if (client < 0) continue;
+        FIXME( "Mouse socket: client connected\n" );
+
+        while (mouse_socket_active)
+        {
+            unsigned char buf[WINE_MOUSE_PKT_SIZE];
+            int n, off = 0;
+            while (off < WINE_MOUSE_PKT_SIZE)
+            {
+                n = read( client, buf + off, WINE_MOUSE_PKT_SIZE - off );
+                if (n <= 0) goto client_done;
+                off += n;
+            }
+            {
+                unsigned int h = __atomic_load_n( &mouse_ring_head, __ATOMIC_RELAXED );
+                unsigned int next = h + 1;
+                if ((next % WINE_MOUSE_RING_SIZE) != (__atomic_load_n( &mouse_ring_tail, __ATOMIC_ACQUIRE ) % WINE_MOUSE_RING_SIZE))
+                {
+                    memcpy( &mouse_ring[h % WINE_MOUSE_RING_SIZE], buf, WINE_MOUSE_PKT_SIZE );
+                    __atomic_store_n( &mouse_ring_head, next, __ATOMIC_RELEASE );
+                }
+            }
+        }
+    client_done:
+        close( client );
+        FIXME( "Mouse socket: client disconnected\n" );
+    }
+    close( srv );
+    unlink( sock_path );
+    return NULL;
+}
 #endif
 
