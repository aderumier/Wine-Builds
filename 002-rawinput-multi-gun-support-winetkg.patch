+/* Virtual raw mouse socket injection */
+#define WINE_RAWMOUSE_MAX        8
+#define WINE_MOUSE_SOCK_DEFAULT  "/tmp/wine-mouse.sock"
+#define WINE_MPKT_ABSOLUTE       0x01
+
+#pragma pack(push, 1)
+struct wine_mouse_pkt
+{
+    unsigned char index;    /* 0-based virtual mouse index */
+    unsigned char buttons;  /* current state: bit0=left, bit1=right, bit2=middle */
+    unsigned char flags;    /* WINE_MPKT_ABSOLUTE */
+    unsigned char pad;
+    int           x;        /* screen pixels if absolute, mickeys if relative */
+    int           y;
+};
+#pragma pack(pop)
+
+static int           mouse_socket_count;
+static unsigned char mouse_prev_buttons[WINE_RAWMOUSE_MAX];
+
+static void inject_mouse_packet( const struct wine_mouse_pkt *pkt )
+{
+    unsigned char changed;
+    INPUT input;
+
+    if (pkt->index >= (unsigned char)mouse_socket_count) return;
+
+    memset( &input, 0, sizeof(input) );
+    input.type           = INPUT_MOUSE;
+    input.mi.dwExtraInfo = 0x10001 + pkt->index;
+    input.mi.dx          = pkt->x;
+    input.mi.dy          = pkt->y;
+    input.mi.dwFlags     = MOUSEEVENTF_MOVE;
+    if (pkt->flags & WINE_MPKT_ABSOLUTE)
+        input.mi.dwFlags |= MOUSEEVENTF_ABSOLUTE;
+    NtUserSendHardwareInput( 0, SEND_HWMSG_NO_MSG, &input, 0 );
+
+    changed = mouse_prev_buttons[pkt->index] ^ pkt->buttons;
+    if (changed)
+    {
+        memset( &input, 0, sizeof(input) );
+        input.type           = INPUT_MOUSE;
+        input.mi.dwExtraInfo = 0x10001 + pkt->index;
+        input.mi.dx          = pkt->x;
+        input.mi.dy          = pkt->y;
+        if (changed & 1) input.mi.dwFlags |= (pkt->buttons & 1) ? MOUSEEVENTF_LEFTDOWN  : MOUSEEVENTF_LEFTUP;
+        if (changed & 2) input.mi.dwFlags |= (pkt->buttons & 2) ? MOUSEEVENTF_RIGHTDOWN : MOUSEEVENTF_RIGHTUP;
+        if (changed & 4) input.mi.dwFlags |= (pkt->buttons & 4) ? MOUSEEVENTF_MIDDLEDOWN: MOUSEEVENTF_MIDDLEUP;
+        NtUserSendHardwareInput( 0, SEND_HWMSG_NO_MSG, &input, 0 );
+        mouse_prev_buttons[pkt->index] = pkt->buttons;
+    }
+}
+
+static void *mouse_socket_thread( void *arg )
+{
+    const char *path = getenv( "WINE_MOUSE_SOCKET" );
+    struct sockaddr_un addr;
+    int srv, client;
+
+    if (!path) path = WINE_MOUSE_SOCK_DEFAULT;
+    unlink( path );
+
+    if ((srv = socket( AF_UNIX, SOCK_STREAM, 0 )) < 0) return NULL;
+    memset( &addr, 0, sizeof(addr) );
+    addr.sun_family = AF_UNIX;
+    memcpy( addr.sun_path, path, strnlen( path, sizeof(addr.sun_path) - 1 ) );
+    if (bind( srv, (struct sockaddr *)&addr, sizeof(addr) ) < 0) { close( srv ); return NULL; }
+    chmod( path, 0666 );
+    listen( srv, 4 );
+    TRACE( "virtual mouse socket listening on %s\n", path );
+
+    for (;;)
+    {
+        client = accept( srv, NULL, NULL );
+        if (client < 0) continue;
+        TRACE( "virtual mouse client connected\n" );
+        for (;;)
+        {
+            struct wine_mouse_pkt pkt;
+            unsigned char *buf = (unsigned char *)&pkt;
+            int off = 0, n;
+            while (off < (int)sizeof(pkt))
+            {
+                n = read( client, buf + off, sizeof(pkt) - off );
+                if (n <= 0) goto client_done;
+                off += n;
+            }
+            inject_mouse_packet( &pkt );
+        }
+    client_done:
+        close( client );
+        TRACE( "virtual mouse client disconnected\n" );
+    }
+}
+
+static void start_mouse_socket_thread( void )
+{
+    const char *env = getenv( "WINE_RAWMOUSE_COUNT" );
+    int count = env ? atoi( env ) : 0;
+    pthread_t tid;
+
+    if (count <= 0 || count > WINE_RAWMOUSE_MAX) return;
+    mouse_socket_count = count;
+    if (pthread_create( &tid, NULL, mouse_socket_thread, NULL ) == 0)
+        pthread_detach( tid );
+}
+
 #ifdef HAVE_X11_EXTENSIONS_XINPUT_H
 #define MAKE_FUNCPTR(f) static typeof(f) * p##f
 MAKE_FUNCPTR(XOpenDevice);
@@ -440,6 +553,11 @@ void x11drv_xinput2_init( struct x11drv_thread_data *data )
     }
 
     TRACE( "XInput2 %d.%d available\n", major, minor );
+
+    {
+        static pthread_once_t once = PTHREAD_ONCE_INIT;
+        pthread_once( &once, start_mouse_socket_thread );
+    }
 }
 
